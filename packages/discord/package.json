{
	"name": "@mariozechner/pi-discord",
	"version": "0.62.0",
	"description": "Discord bot that delegates messages to the pi coding agent",
	"type": "module",
	"bin": {
		"pi-discord": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsc -p tsconfig.build.json && shx chmod +x dist/main.js",
		"dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@anthropic-ai/sandbox-runtime": "^0.0.16",
		"@mariozechner/pi-agent-core": "^0.62.0",
		"@mariozechner/pi-ai": "^0.62.0",
		"@mariozechner/pi-coding-agent": "^0.62.0",
		"@sinclair/typebox": "^0.34.0",
		"chalk": "^5.6.2",
		"croner": "^9.1.0",
		"diff": "^8.0.2",
		"discord.js": "^14.18.0",
		"duck-duck-scrape": "^2.2.7",
		"playwright": "^1.58.2"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"shx": "^0.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"keywords": [
		"discord",
		"bot",
		"ai",
		"agent"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/badlogic/pi-mono.git",
		"directory": "packages/discord"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
